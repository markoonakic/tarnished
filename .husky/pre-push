#!/bin/sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
BACKEND_BIN="$ROOT/backend/.venv/bin"
CLI_BIN="$ROOT/cli/.venv/bin"
FRONTEND_BIN="$ROOT/frontend/node_modules/.bin"
EXTENSION_BIN="$ROOT/extension/node_modules/.bin"

require_executable() {
  if [ ! -x "$1" ]; then
    echo "Missing required tool: $1"
    exit 1
  fi
}

BASE_REF="$(git merge-base HEAD origin/main 2>/dev/null || true)"
if [ -n "$BASE_REF" ]; then
  CHANGED_FILES="$(git diff --name-only "$BASE_REF"..HEAD)"
else
  CHANGED_FILES="$(git diff --name-only HEAD)"
fi

has_changes() {
  printf '%s\n' "$CHANGED_FILES" | grep -Eq "$1"
}

backend_changed_python_files() {
  printf '%s\n' "$CHANGED_FILES" | grep -E '^backend/.*\.py$' || true
}

cli_changed_python_files() {
  printf '%s\n' "$CHANGED_FILES" | grep -E '^cli/.*\.py$' || true
}

echo "Running pre-push checks..."

if has_changes '^backend/'; then
  require_executable "$BACKEND_BIN/ruff"
  require_executable "$BACKEND_BIN/pyright"
  BACKEND_CHANGED="$(backend_changed_python_files)"
  cd "$ROOT/backend"
  if [ -n "$BACKEND_CHANGED" ]; then
    echo ">> Backend: ruff check (changed files)"
    printf '%s\n' "$BACKEND_CHANGED" | sed "s#^backend/##" | xargs "$BACKEND_BIN/ruff" check
  fi
  echo ">> Backend: pyright"
  "$BACKEND_BIN/pyright"
fi

if has_changes '^cli/'; then
  require_executable "$CLI_BIN/ruff"
  require_executable "$CLI_BIN/pyright"
  CLI_CHANGED="$(cli_changed_python_files)"
  cd "$ROOT/cli"
  if [ -n "$CLI_CHANGED" ]; then
    echo ">> CLI: ruff check (changed files)"
    printf '%s\n' "$CLI_CHANGED" | sed "s#^cli/##" | xargs "$CLI_BIN/ruff" check
  fi
  echo ">> CLI: pyright"
  "$CLI_BIN/pyright" src tests
fi

if has_changes '^frontend/'; then
  require_executable "$FRONTEND_BIN/eslint"
  require_executable "$FRONTEND_BIN/tsc"
  cd "$ROOT/frontend"
  echo ">> Frontend: lint"
  "$FRONTEND_BIN/eslint" .
  echo ">> Frontend: typecheck"
  "$FRONTEND_BIN/tsc" --noEmit
fi

if has_changes '^extension/'; then
  require_executable "$EXTENSION_BIN/tsc"
  cd "$ROOT/extension"
  echo ">> Extension: typecheck"
  "$EXTENSION_BIN/tsc" --noEmit
fi

echo "All pre-push checks passed!"

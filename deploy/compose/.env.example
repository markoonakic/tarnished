# Optional overrides for Tarnished Docker Compose installs

# Published Tarnished image to run
# TARNISHED_IMAGE=ghcr.io/markoonakic/tarnished:0.1.7

# External port (default: 5577)
# APP_PORT=5577

# Public URL of your instance
# APP_URL=https://jobs.yourdomain.com

# Required for deploy/compose/docker-compose.postgres.yml
# POSTGRES_PASSWORD=your-secure-password
